ENVIRONMENT=development
LOG_LEVEL=INFO
JWT_ISSUER=https://auth.example.health/
JWT_AUDIENCE=healthgov-api
JWKS_URL=https://auth.example.health/.well-known/jwks.json
DATABASE_URL=postgresql+asyncpg://healthgov:change-me@postgres:5432/healthgov
REDIS_URL=redis://redis:6379/0
OPA_URL=http://opa:8181
AUDIT_SERVICE_URL=http://audit-service:8000
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_SECURITY_PROTOCOL=PLAINTEXT
SMART_ISSUER=https://ehr.example.health
SMART_AUDIENCE=healthgov-fhir
TOKENIZATION_KEY=replace-with-32-byte-base64-key-from-vault
SPLUNK_HEC_URL=https://splunk.example.health:8088/services/collector
SPLUNK_HEC_TOKEN=retrieve-from-vault
