ENVIRONMENT=development
LOG_LEVEL=INFO
DATABASE_URL=postgresql+asyncpg://postgres:change-me@localhost:5432/railway
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_SECURITY_PROTOCOL=PLAINTEXT
KAFKA_SSL_CAFILE=
KAFKA_SSL_CERTFILE=
KAFKA_SSL_KEYFILE=
JWT_ISSUER=https://auth.example.health/
JWT_AUDIENCE=healthgov-api
JWKS_URL=https://auth.example.health/.well-known/jwks.json
HAPI_FHIR_BASE_URL=http://localhost:8080/fhir
HAPI_FHIR_TOKEN=
TOKENIZATION_SECRET=replace-with-at-least-32-characters-from-railway-secret
SYNTHEA_OUTPUT_DIR=./data/synthea
MIMIC_DATA_DIR=./data/mimic
DICOM_QUARANTINE_DIR=./data/dicom-quarantine
BATCH_SIZE=500
ENABLE_SCHEDULED_PIPELINES=false

