ENVIRONMENT=development
LOG_LEVEL=INFO
DATABASE_URL=postgresql+asyncpg://healthgov:change-me@localhost:5432/healthgov
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20
JWKS_URL=http://localhost:8080/.well-known/jwks.json
JWT_ISSUER=https://auth.healthgov.local/
JWT_AUDIENCE=healthgov-api
TOKENIZATION_SECRET=replace-with-a-random-secret-at-least-32-characters
