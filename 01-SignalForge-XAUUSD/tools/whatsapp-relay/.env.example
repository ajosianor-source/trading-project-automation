# Copy this file to .env. Never share or commit the real .env file.
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=replace_with_your_private_auth_token

# Include the country code, for example +447700900123.
TWILIO_WHATSAPP_TO=+44xxxxxxxxxx

# Twilio Sandbox sender. Replace this only after registering a production sender.
TWILIO_WHATSAPP_FROM=+14155238886

# Optional SMS fallback. Requires a Twilio SMS-capable phone number.
# If your Twilio account is still trial, the receiving phone may need to be
# verified inside Twilio first.
TWILIO_SMS_FROM=+1xxxxxxxxxx
TWILIO_SMS_TO=+44xxxxxxxxxx

# Optional. Use whatsapp only, sms only, or whatsapp,sms.
# If omitted, the relay uses WhatsApp and automatically adds SMS only when
# TWILIO_SMS_FROM and TWILIO_SMS_TO are filled.
TWILIO_ALERT_CHANNELS=whatsapp,sms
